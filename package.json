{
  "name": "gha-dash",
  "version": "0.3.0",
  "description": "GitHub Actions dashboard — workflow status across multiple orgs/accounts",
  "type": "module",
  "bin": {
    "gha-dash": "dist/cli.js"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/cli.ts --no-open",
    "dev:client": "vite --config src/client/vite.config.ts --open",
    "build:server": "tsup && printf '#!/usr/bin/env node\\n' | cat - dist/cli.js > dist/cli.tmp && mv dist/cli.tmp dist/cli.js",
    "build:client": "vite build --config src/client/vite.config.ts",
    "build": "npm run build:server && npm run build:client",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "keywords": [
    "github",
    "actions",
    "dashboard",
    "workflow",
    "ci",
    "cd"
  ],
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/photostructure/gha-dash.git"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "express": "^5.2.1",
    "p-limit": "^7.3.0",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.2.1",
    "msw": "^2.12.14",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
