{
  "name": "gha-dash",
  "version": "0.1.0",
  "description": "GitHub Actions dashboard — workflow status across multiple orgs/accounts",
  "type": "module",
  "bin": {
    "gha-dash": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "keywords": [
    "github",
    "actions",
    "dashboard",
    "workflow",
    "ci",
    "cd"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "p-limit": "^7.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "msw": "^2.12.14",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
