<%- include('head') %>

<div class="dashboard">
  <%- include('partials/error-banner') %>
  <div class="toolbar">
    <input
      type="text"
      id="search"
      placeholder="Search workflows..."
      aria-label="Search workflows"
      oninput="applyFilters()"
    >
    <label class="filter-toggle">
      <input type="checkbox" id="failures-only" onchange="applyFilters()">
      Failures only
    </label>
  </div>

  <table class="workflow-table">
    <thead>
      <tr>
        <th scope="col" data-sort="workflow" class="sortable">Workflow</th>
        <th scope="col" data-sort="branch" class="sortable">Branch</th>
        <th scope="col" data-sort="status" class="sortable">Status</th>
        <th scope="col">Commit</th>
        <th scope="col">Message</th>
        <th scope="col" data-sort="started" class="sortable sort-active sort-desc">Started</th>
        <th scope="col" data-sort="duration" class="sortable">Duration</th>
        <th scope="col" class="actions-col"></th>
      </tr>
    </thead>
    <tbody
      id="workflow-rows"
      hx-get="/partials/workflows"
      hx-trigger="every 30s"
      hx-swap="innerHTML"
      aria-live="polite"
    >
      <%- include('partials/workflow-table') %>
    </tbody>
  </table>

  <% if (rateLimit) { %>
    <footer class="rate-limit">
      API: <%= rateLimit.remaining %> / <%= rateLimit.limit %> remaining
    </footer>
  <% } %>
</div>

<script>
// --- Filtering ---
function applyFilters() {
  var q = (document.getElementById('search').value || '').toLowerCase();
  var failOnly = document.getElementById('failures-only').checked;
  var failStatuses = ['failure', 'timed_out'];

  document.querySelectorAll('#workflow-rows tr').forEach(function(row) {
    if (row.classList.contains('repo-header') || row.classList.contains('dispatch-row')) {
      // Don't hide headers or dispatch rows directly — handled by group visibility
      return;
    }

    var matchesSearch = !q || row.textContent.toLowerCase().includes(q);
    var matchesFail = true;
    if (failOnly) {
      var badge = row.querySelector('.status-badge');
      matchesFail = badge && failStatuses.some(function(s) {
        return badge.classList.contains('status-' + s);
      });
    }

    row.style.display = (matchesSearch && matchesFail) ? '' : 'none';
  });

  // Hide repo headers if all their rows are hidden
  document.querySelectorAll('.repo-header').forEach(function(header) {
    var repo = header.getAttribute('data-repo-header');
    var rows = document.querySelectorAll('tr[data-repo="' + repo + '"]:not(.dispatch-row)');
    var anyVisible = Array.from(rows).some(function(r) { return r.style.display !== 'none'; });
    header.style.display = anyVisible ? '' : 'none';
  });
}

// --- Column Sorting ---
var currentSort = { col: 'started', desc: true };

document.querySelectorAll('th.sortable').forEach(function(th) {
  th.addEventListener('click', function() {
    var col = th.getAttribute('data-sort');
    if (currentSort.col === col) {
      currentSort.desc = !currentSort.desc;
    } else {
      currentSort.col = col;
      currentSort.desc = col === 'started' || col === 'duration'; // default desc for time cols
    }
    sortTable();
    updateSortIndicators();
  });
});

function updateSortIndicators() {
  document.querySelectorAll('th.sortable').forEach(function(th) {
    th.classList.remove('sort-active', 'sort-asc', 'sort-desc');
    if (th.getAttribute('data-sort') === currentSort.col) {
      th.classList.add('sort-active', currentSort.desc ? 'sort-desc' : 'sort-asc');
    }
  });
}

function sortTable() {
  var tbody = document.getElementById('workflow-rows');
  // Collect repo groups: header + its rows
  var groups = [];
  var currentGroup = null;

  Array.from(tbody.children).forEach(function(row) {
    if (row.classList.contains('repo-header')) {
      currentGroup = { header: row, rows: [] };
      groups.push(currentGroup);
    } else if (currentGroup) {
      currentGroup.rows.push(row);
    }
  });

  // Sort rows within each group
  var col = currentSort.col;
  var desc = currentSort.desc;

  groups.forEach(function(g) {
    // Separate workflow rows from dispatch rows (keep dispatch rows after their workflow)
    var workflowRows = [];
    var dispatchMap = new Map();

    g.rows.forEach(function(row) {
      if (row.classList.contains('dispatch-row')) {
        // Attach to previous workflow row
        if (workflowRows.length > 0) {
          dispatchMap.set(workflowRows[workflowRows.length - 1], row);
        }
      } else {
        workflowRows.push(row);
      }
    });

    workflowRows.sort(function(a, b) {
      var va = getSortValue(a, col);
      var vb = getSortValue(b, col);
      var cmp = va < vb ? -1 : va > vb ? 1 : 0;
      return desc ? -cmp : cmp;
    });

    // Rebuild sorted rows with dispatch rows attached
    g.rows = [];
    workflowRows.forEach(function(row) {
      g.rows.push(row);
      if (dispatchMap.has(row)) g.rows.push(dispatchMap.get(row));
    });
  });

  // Re-append everything in sorted order
  groups.forEach(function(g) {
    tbody.appendChild(g.header);
    g.rows.forEach(function(row) { tbody.appendChild(row); });
  });
}

function getSortValue(row, col) {
  var cells = row.querySelectorAll('td');
  switch (col) {
    case 'workflow': return (cells[0] && cells[0].textContent || '').toLowerCase();
    case 'branch': return (cells[1] && cells[1].textContent || '').toLowerCase();
    case 'status':
      var badge = row.querySelector('.status-badge');
      return badge ? badge.textContent.trim() : '';
    case 'started':
      // Use the title attribute which has the full date
      return cells[5] ? cells[5].getAttribute('title') || '' : '';
    case 'duration':
      // Parse duration text back to sortable value
      return parseDurationForSort(cells[6] ? cells[6].textContent.trim() : '');
    default: return '';
  }
}

function parseDurationForSort(text) {
  var total = 0;
  var m = text.match(/(\d+)h/); if (m) total += parseInt(m[1]) * 3600;
  m = text.match(/(\d+)m/); if (m) total += parseInt(m[1]) * 60;
  m = text.match(/(\d+)s/); if (m) total += parseInt(m[1]);
  return String(total).padStart(10, '0');
}

// --- Collapse State ---
document.body.addEventListener('htmx:afterSwap', function(e) {
  if (e.detail.target.id === 'workflow-rows') {
    restoreCollapseState();
    applyFilters();
    // Re-sort after new data
    sortTable();
    updateSortIndicators();
  }
});

function toggleRepo(repo) {
  var state = JSON.parse(localStorage.getItem('gha-dash-collapsed') || '{}');
  state[repo] = !state[repo];
  localStorage.setItem('gha-dash-collapsed', JSON.stringify(state));
  applyCollapse(repo, state[repo]);
}

function applyCollapse(repo, collapsed) {
  document.querySelectorAll('tr[data-repo="' + repo + '"]').forEach(function(row) {
    row.style.display = collapsed ? 'none' : '';
  });
  var header = document.querySelector('tr[data-repo-header="' + repo + '"]');
  if (header) {
    header.setAttribute('aria-expanded', String(!collapsed));
    header.querySelector('.collapse-icon').textContent = collapsed ? '\u25B6' : '\u25BC';
  }
}

function restoreCollapseState() {
  var state = JSON.parse(localStorage.getItem('gha-dash-collapsed') || '{}');
  Object.keys(state).forEach(function(repo) {
    if (state[repo]) applyCollapse(repo, true);
  });
}

restoreCollapseState();
</script>

<%- include('foot') %>
