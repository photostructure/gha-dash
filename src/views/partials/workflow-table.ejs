<% if (grouped.length === 0) { %>
  <tr><td colspan="8" class="loading">Loading workflow data...</td></tr>
<% } else { %>
  <% for (const group of grouped) { %>
    <tr
      class="repo-header"
      data-repo-header="<%= group.repo %>"
      aria-expanded="true"
      onclick="toggleRepo('<%= group.repo %>')"
      role="button"
      tabindex="0"
      onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();toggleRepo('<%= group.repo %>')}"
    >
      <td colspan="8">
        <span class="collapse-icon">&#x25BC;</span>
        <strong><%= group.repo %></strong>
        <% if (group.error) { %>
          <span class="error-badge" title="<%= group.error %>">&#x26A0; error</span>
        <% } %>
        <button
          type="button"
          class="btn-refresh"
          hx-post="/refresh/<%= group.repo %>"
          hx-target="#workflow-rows"
          hx-swap="innerHTML"
          onclick="event.stopPropagation()"
          title="Refresh <%= group.repo %>"
          aria-label="Refresh <%= group.repo %>"
        ><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="transform:scaleX(-1)"><path d="M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1.01-.25 1.97-.7 2.8l1.46 1.46C19.54 15.03 20 13.57 20 12c0-4.42-3.58-8-8-8zm0 14c-3.31 0-6-2.69-6-6 0-1.01.25-1.97.7-2.8L5.24 7.74C4.46 8.97 4 10.43 4 12c0 4.42 3.58 8 8 8v3l4-4-4-4v3z"/></svg></button>
      </td>
    </tr>
    <% for (const run of group.runs) { %>
      <tr data-repo="<%= group.repo %>">
        <td><a href="https://github.com/<%= run.repo %>/actions/workflows/<%= run.workflowPath.split('/').pop() %>" target="_blank" rel="noopener"><%= run.workflowName %></a></td>
        <td><code><%= run.branch %></code></td>
        <td>
          <% const status = displayStatus(run); %>
          <span
            class="status-badge status-<%= status %>"
            aria-label="Status: <%= status %>"
          ><%= status %></span>
        </td>
        <td><code><%= run.commitSha %></code></td>
        <td class="message-col"><a href="<%= run.htmlUrl %>" target="_blank" rel="noopener"><%= run.commitMessage %></a></td>
        <td title="<%= new Date(run.createdAt).toLocaleString() %>"><%= relativeTime(run.createdAt) %></td>
        <td><%= formatDuration(run.duration) %></td>
        <td class="actions-col">
          <button
            type="button"
            class="btn-dispatch"
            hx-get="/dispatch/<%= run.repo.split('/')[0] %>/<%= run.repo.split('/')[1] %>/<%= run.workflowId %>"
            hx-target="#dispatch-row-<%= run.workflowId %>-<%= run.branch.replace(/[^a-zA-Z0-9]/g, '-') %>"
            hx-swap="innerHTML"
            title="Run workflow"
            aria-label="Run <%= run.workflowName %>"
          >&#x25B6;</button>
        </td>
      </tr>
      <tr id="dispatch-row-<%= run.workflowId %>-<%= run.branch.replace(/[^a-zA-Z0-9]/g, '-') %>" class="dispatch-row" data-repo="<%= run.repo %>">
        <td colspan="8"></td>
      </tr>
    <% } %>
  <% } %>
<% } %>
