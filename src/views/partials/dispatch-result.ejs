<div class="dispatch-result <%= success ? 'dispatch-success' : 'dispatch-error' %>">
  <% if (success) { %>
    <p>&#x2705; <%= message %></p>
    <p><a href="https://github.com/<%= owner %>/<%= repo %>/actions" target="_blank" rel="noopener">View runs on GitHub</a></p>
  <% } else { %>
    <p>&#x274C; <%= message %></p>
  <% } %>
</div>
