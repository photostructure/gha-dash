<%- include('head') %>

<div class="settings">
  <h2>Settings</h2>
  <p>Select organizations and repos to monitor.</p>

  <div class="settings-layout">
    <div class="org-list">
      <h3>Organizations</h3>
      <div
        hx-get="/partials/orgs"
        hx-trigger="load"
        hx-swap="innerHTML"
      >
        Loading organizations...
      </div>
    </div>

    <div class="repo-list">
      <h3>Repositories</h3>
      <form method="POST" action="/settings/repos" id="repo-form">
        <div id="repo-container">
          <p class="hint">Select an organization to see its repos.</p>
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
      </form>
    </div>
  </div>
</div>

<%- include('foot') %>
