<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>gha-dash</title>
  <link rel="stylesheet" href="/style.css">
  <script src="/htmx.min.js"></script>
</head>
<body>
  <header>
    <h1><a href="/">gha-dash</a></h1>
    <nav>
      <% if (typeof page !== 'undefined' && page === 'settings') { %>
        <a href="/">&larr; Dashboard</a>
      <% } else { %>
        <button
          type="button"
          class="btn-refresh-all"
          hx-post="/refresh"
          hx-target="#workflow-rows"
          hx-swap="innerHTML"
          title="Refresh all repos"
        >&#x21BB; Refresh</button>
        <a href="/settings">&#9881; Settings</a>
      <% } %>
    </nav>
  </header>
