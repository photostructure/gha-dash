<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>gha-dash</title>
  <link rel="stylesheet" href="/style.css">
  <script src="/htmx.min.js"></script>
</head>
<body>
  <header>
    <h1><a href="/">gha-dash</a></h1>
    <nav>
      <% if (typeof page !== 'undefined' && page === 'settings') { %>
        <a href="/">&larr; Dashboard</a>
      <% } else { %>
        <span id="rate-limit-badge"><%- include('partials/rate-limit') %></span>
        <button
          type="button"
          class="btn-refresh-all"
          hx-post="/refresh"
          hx-target="#workflow-rows"
          hx-swap="innerHTML"
          title="Refresh all repos"
        ><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="transform:scaleX(-1)"><path d="M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1.01-.25 1.97-.7 2.8l1.46 1.46C19.54 15.03 20 13.57 20 12c0-4.42-3.58-8-8-8zm0 14c-3.31 0-6-2.69-6-6 0-1.01.25-1.97.7-2.8L5.24 7.74C4.46 8.97 4 10.43 4 12c0 4.42 3.58 8 8 8v3l4-4-4-4v3z"/></svg> Refresh</button>
        <a href="/settings">&#9881; Settings</a>
      <% } %>
    </nav>
  </header>
  <main>
